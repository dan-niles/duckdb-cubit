# name: test_cubit_count.test
# description: Test CUBIT index count optimization for SELECT count(col) FROM tbl WHERE col = value
# group: [cubit]

# Load the CUBIT extension
# statement ok
# LOAD 'cubit.duckdb_extension'; # Adjust path if necessary, or ensure auto-loading

# Require CUBIT extension to be loaded for these tests to run
require cubit

#--------------------------------------------------------------------
# Test Case: Basic Count with INTEGER
#--------------------------------------------------------------------
statement ok
CREATE TABLE T1(i INTEGER);

statement ok
CREATE INDEX cubit_idx_t1 ON T1 USING CUBIT (i);

statement ok
INSERT INTO T1 VALUES (1), (1), (2), (3), (3), (3), (1);

query II
SELECT count(i) FROM T1 WHERE i = 1;
----
3

query II
SELECT count(i) FROM T1 WHERE i = 3;
----
3

query II
SELECT count(i) FROM T1 WHERE i = 2;
----
1

# Verify with EXPLAIN
query TT
EXPLAIN SELECT count(i) FROM T1 WHERE i = 1;
----
## PHYSICAL_PROJECTION ##
## cubit_index_count(T1) ##

query TT
EXPLAIN SELECT count(i) FROM T1 WHERE i = 2;
----
## PHYSICAL_PROJECTION ##
## cubit_index_count(T1) ##

#--------------------------------------------------------------------
# Test Case: Value Not Present (INTEGER)
#--------------------------------------------------------------------
query II
SELECT count(i) FROM T1 WHERE i = 5;
----
0

# Verify with EXPLAIN
query TT
EXPLAIN SELECT count(i) FROM T1 WHERE i = 5;
----
## PHYSICAL_PROJECTION ##
## cubit_index_count(T1) ##

#--------------------------------------------------------------------
# Test Case: Empty Table (INTEGER)
#--------------------------------------------------------------------
statement ok
CREATE TABLE T_empty(i INTEGER);

statement ok
CREATE INDEX cubit_idx_empty ON T_empty USING CUBIT (i);

query II
SELECT count(i) FROM T_empty WHERE i = 1;
----
0

# Verify with EXPLAIN
query TT
EXPLAIN SELECT count(i) FROM T_empty WHERE i = 1;
----
## PHYSICAL_PROJECTION ##
## cubit_index_count(T_empty) ##

statement ok
DROP TABLE T_empty;

#--------------------------------------------------------------------
# Test Case: Table with NULLs (INTEGER)
# CUBIT index count optimization is for `col = value`, NULLs in the column
# but not part of the count condition should be fine.
# `count(i)` itself ignores NULLs.
#--------------------------------------------------------------------
statement ok
CREATE TABLE T_nulls(i INTEGER);

statement ok
CREATE INDEX cubit_idx_nulls ON T_nulls USING CUBIT (i);

statement ok
INSERT INTO T_nulls VALUES (1), (NULL), (1), (NULL), (2), (1);

query II
SELECT count(i) FROM T_nulls WHERE i = 1;
----
3

query II
SELECT count(i) FROM T_nulls WHERE i = 2;
----
1

# Verify with EXPLAIN
query TT
EXPLAIN SELECT count(i) FROM T_nulls WHERE i = 1;
----
## PHYSICAL_PROJECTION ##
## cubit_index_count(T_nulls) ##

# Query for a value not present in T_nulls
query II
SELECT count(i) FROM T_nulls WHERE i = 7;
----
0

# Verify with EXPLAIN
query TT
EXPLAIN SELECT count(i) FROM T_nulls WHERE i = 7;
----
## PHYSICAL_PROJECTION ##
## cubit_index_count(T_nulls) ##

statement ok
DROP TABLE T_nulls;

#--------------------------------------------------------------------
# Test Case: Basic Count with VARCHAR
#--------------------------------------------------------------------
statement ok
CREATE TABLE T_varchar(v VARCHAR);

statement ok
CREATE INDEX cubit_idx_varchar ON T_varchar USING CUBIT (v);

statement ok
INSERT INTO T_varchar VALUES ('apple'), ('banana'), ('apple'), ('orange'), ('apple'), ('banana');

query II
SELECT count(v) FROM T_varchar WHERE v = 'apple';
----
3

query II
SELECT count(v) FROM T_varchar WHERE v = 'banana';
----
2

query II
SELECT count(v) FROM T_varchar WHERE v = 'orange';
----
1

# Verify with EXPLAIN
query TT
EXPLAIN SELECT count(v) FROM T_varchar WHERE v = 'apple';
----
## PHYSICAL_PROJECTION ##
## cubit_index_count(T_varchar) ##

#--------------------------------------------------------------------
# Test Case: Value Not Present (VARCHAR)
#--------------------------------------------------------------------
query II
SELECT count(v) FROM T_varchar WHERE v = 'grape';
----
0

# Verify with EXPLAIN
query TT
EXPLAIN SELECT count(v) FROM T_varchar WHERE v = 'grape';
----
## PHYSICAL_PROJECTION ##
## cubit_index_count(T_varchar) ##


#--------------------------------------------------------------------
# Test Case: Non-Optimized Count (e.g. count(*), different column)
# These should not use the CUBITIndexCountFunction
#--------------------------------------------------------------------
# count(*) should not use the specialized count(column) optimization
query II
SELECT count(*) FROM T1 WHERE i = 1;
----
3

query TT
EXPLAIN SELECT count(*) FROM T1 WHERE i = 1;
----
## PHYSICAL_FILTER ##
## PHYSICAL_SEQ_SCAN ##

# count on a different column than the filter (assuming table T_multi(i, j))
statement ok
CREATE TABLE T_multi(i INTEGER, j INTEGER);

statement ok
CREATE INDEX cubit_idx_multi_i ON T_multi USING CUBIT (i);
CREATE INDEX cubit_idx_multi_j ON T_multi USING CUBIT (j);


statement ok
INSERT INTO T_multi VALUES (1,10), (1,11), (2,10), (1,10);

query II
SELECT count(j) FROM T_multi WHERE i = 1;
----
3

query TT
EXPLAIN SELECT count(j) FROM T_multi WHERE i = 1;
----
## PHYSICAL_FILTER ##
## PHYSICAL_SEQ_SCAN ##

statement ok
DROP TABLE T1;
statement ok
DROP TABLE T_varchar;
statement ok
DROP TABLE T_multi;
